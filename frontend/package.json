{
  "name": "flowtrans-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop": "electron electron/main.cjs",
    "desktop:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 ELECTRON_OPEN_DEVTOOLS=1 electron electron/main.cjs",
    "test": "vitest run",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.flowtrans.app",
    "productName": "FlowTrans",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
